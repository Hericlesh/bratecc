# Database (Vercel Postgres)
POSTGRES_PRISMA_URL="postgresql://user:password@host:5432/database?pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/database"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-here-minimum-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="BRATECC Connect AI <noreply@yourdomain.com>"

# WhatsApp API (Evolution API, Twilio, ou WhatsApp Business API)
WHATSAPP_API_URL="https://your-whatsapp-api-url.com"
WHATSAPP_API_KEY="your_whatsapp_api_key"
